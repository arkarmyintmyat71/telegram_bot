# Copy this file to .env and fill in real values for local development.
# On Railway, don't upload this file — set these as Variables in the
# service's Variables tab instead.

BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# Comma-separated Telegram user IDs allowed to use admin commands
ADMIN_IDS=111111111,222222222

# Local dev default (zero setup). For production, use your Neon connection
# string instead, e.g.:
#   DATABASE_URL=postgresql://user:pass@ep-xxxx.neon.tech/dbname?sslmode=require&channel_binding=require
DATABASE_URL=sqlite+aiosqlite:///bot.db

MESSAGE_RETENTION_DAYS=30
CLEANUP_INTERVAL_HOURS=24
WEBSITE_URL=https://example.com
